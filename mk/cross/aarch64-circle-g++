#!/bin/sh
# Cross C++ compiler for MAME-on-Circle: aarch64-none-elf-g++ against
# circle-stdlib's newlib + libc++ sysroot. Flags appended AFTER the caller's
# arguments deliberately: gcc honours the last -std/-mcpu, so genie's
# defaults are overridden without patching MAME's build scripts.
#
# Requires the Arm GNU aarch64-none-elf toolchain on PATH.

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# Resolve the REAL Arm GNU compiler, skipping any ccache masquerade on PATH.
# ccache is auto-wired here (see the exec below) rather than via a PATH
# masquerade, so `command -v` could otherwise return a ccache symlink and make
# TC — and thus the builtin-include dir -isystem $TCINC — resolve to the wrong
# place (an empty glob -> "stddef.h: No such file"). Walk PATH and take the
# first aarch64-none-elf-g++ that is NOT a symlink into ccache.
REAL=""
_saved_ifs="$IFS"; IFS=:
for _d in $PATH; do
    _c="$_d/aarch64-none-elf-g++"
    [ -x "$_c" ] || continue
    case "$(readlink "$_c" 2>/dev/null)" in *ccache*) continue ;; esac
    REAL="$_c"; break
done
IFS="$_saved_ifs"
[ -n "$REAL" ] || {
    echo "aarch64-circle-g++: aarch64-none-elf-g++ not on PATH" >&2; exit 1; }
TC="$(cd "$(dirname "$REAL")/.." && pwd)"

# ccache automatically, NO `source build/ccache.sh` needed: if ccache is on
# PATH, run the real compiler THROUGH it. Because we invoke $REAL explicitly
# (not a PATH masquerade), this is the single ccache layer — it never wraps
# ccache-around-ccache. Honors any CCACHE_DIR already set (e.g. the RAM disk).
CCACHE=""
command -v ccache >/dev/null 2>&1 && CCACHE=ccache

# Board is selected by RAPI_BOARD (rpi3/rpi4/rpi5); build-mame.sh and host/Makefile
# export it. Each maps to its Circle RASPPI, CPU tuning, and the matching per-board
# multicore world hoisted from circle-libsdl2 — there is no separate circle-stdlib in
# this tree. Defaults to rpi4.
RAPI_BOARD="${RAPI_BOARD:-rpi4}"
case "$RAPI_BOARD" in
    rpi3) RAPI_RASPPI=3; RAPI_MCPU=cortex-a53 ;;
    rpi4) RAPI_RASPPI=4; RAPI_MCPU=cortex-a72 ;;
    rpi5) RAPI_RASPPI=5; RAPI_MCPU=cortex-a76 ;;
    *) echo "aarch64-circle-g++: unknown RAPI_BOARD='$RAPI_BOARD' (rpi3|rpi4|rpi5)" >&2; exit 1 ;;
esac
STDLIB=$ROOT/circle-libsdl2/circle-stdlib-$RAPI_BOARD
INSTALL=$STDLIB/install/aarch64-none-circle
TCINC="$(echo "$TC"/lib/gcc/aarch64-none-elf/*/include)"

exec $CCACHE "$REAL" "$@" \
    -mcpu=$RAPI_MCPU -mlittle-endian \
    -std=gnu++23 -Wno-volatile \
    -Wno-alloc-size-larger-than \
    -nostdinc \
    -isystem "$INSTALL-libc++/include" \
    -isystem "$INSTALL-libc++/include/c++/v1" \
    -isystem "$INSTALL-libc++-threading/include" \
    -isystem "$ROOT/mk/cross/compat" \
    -isystem "$INSTALL/include" \
    -isystem "$STDLIB/include" \
    -isystem "$STDLIB/libs/circle/include" \
    -isystem "$STDLIB/libs/circle/addon" \
    -isystem "$TCINC" \
    -D__circle__ -DAARCH=64 -DRASPPI=$RAPI_RASPPI -DARM_ALLOW_MULTI_CORE \
    -D__LINUX_ERRNO_EXTENSIONS__ \
    -D_GNU_SOURCE -D_POSIX_C_SOURCE=200809L \
    -D_POSIX_TIMERS=1 -D_POSIX_MONOTONIC_CLOCK=200112L \
    -D_POSIX_PRIORITY_SCHEDULING=1 \
    -DBX_CRT_NEWLIB=1 \
    -DBX_CONFIG_SUPPORTS_THREADING=0 \
    -DBGFX_CONFIG_MULTITHREADED=0 \
    -Wno-free-nonheap-object
